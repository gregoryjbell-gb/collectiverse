generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Person {
  id           String       @id @default(cuid())
  displayName  String       @map("display_name")
  aliases      String[]     @default([])
  birthDate    String?      @map("birth_date")
  biography    String?
  achievements String[]     @default([])
  hallOfFame   Boolean      @default(false) @map("hall_of_fame")
  imageUrl     String?      @map("image_url")
  funFacts     String[]     @default([]) @map("fun_facts")
  whyCollectorsCare String? @map("why_collectors_care")
  subjectType  String       @default("ATHLETE") @map("subject_type") // ATHLETE, CHARACTER, ACTOR, MUSICIAN, HISTORICAL_FIGURE, POLITICIAN, CREATOR, CELEBRITY, OTHER
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  personTeams  PersonTeam[]
  personSports PersonSport[]
  cards        Card[]

  @@map("persons")
}

model Sport {
  id     String @id @default(cuid())
  name   String @unique
  league String?

  teams        Team[]
  sets         CardSet[]
  personSports PersonSport[]

  @@map("sports")
}

model Team {
  id       String  @id @default(cuid())
  name     String  @map("team_name")
  sportId  String  @map("sport_id")
  city     String?
  colors   String[]  @default([])
  logoUrl  String?   @map("logo_url")

  sport       Sport        @relation(fields: [sportId], references: [id])
  personTeams PersonTeam[]
  cards       Card[]

  @@map("teams")
}

model PersonTeam {
  id        String  @id @default(cuid())
  personId  String  @map("person_id")
  teamId    String  @map("team_id")
  startYear Int?    @map("start_year")
  endYear   Int?    @map("end_year")

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("person_teams")
}

model PersonSport {
  id       String @id @default(cuid())
  personId String @map("person_id")
  sportId  String @map("sport_id")

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  sport  Sport  @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@unique([personId, sportId])
  @@map("person_sports")
}

model CardSet {
  id                 String   @id @default(cuid())
  name               String
  normalizedName     String?  @map("normalized_name")
  year               Int
  manufacturer       String?
  manufacturerId     String?  @map("manufacturer_id")
  brandId            String?  @map("brand_id")
  productReleaseId   String?  @map("product_release_id")
  checklistSectionId String?  @map("checklist_section_id")
  sportId            String?  @map("sport_id")
  releaseDate        String?  @map("release_date")
  category           String?  // SPORTS, TCG, ENTERTAINMENT, etc.
  franchise          String?
  publisher          String?
  licenseHolder      String?  @map("license_holder")
  aliases            String?  // JSON array
  createdAt          DateTime @default(now()) @map("created_at")

  sport Sport? @relation(fields: [sportId], references: [id])
  cards Card[]
  inventoryGroups InventoryGroup[]

  @@map("card_sets")
}

model Card {
  id                    String   @id @default(cuid())
  personId              String?  @map("person_id")
  setId                 String?  @map("set_id")
  teamId                String?  @map("team_id")
  manufacturerId        String?  @map("manufacturer_id")
  brandId               String?  @map("brand_id")
  productReleaseId      String?  @map("product_release_id")
  checklistSectionId    String?  @map("checklist_section_id")
  year                  Int?
  cardNumber            String?  @map("card_number")
  parallel              String?
  rookie                Boolean  @default(false)
  autograph             Boolean  @default(false)
  relic                 Boolean  @default(false)
  serialNumber          String?  @map("serial_number")
  printRun              Int?     @map("print_run")
  frontImageUrl         String?  @map("front_image_url")
  backImageUrl          String?  @map("back_image_url")
  qrCodeUrl             String?  @map("qr_code_url")
  estimatedValue        Float?   @map("estimated_value")
  gradingRecommendation String?  @map("grading_recommendation")
  status                String   @default("hold")
  inventoryLocation     String?  @map("inventory_location")
  funFacts              String[] @default([]) @map("fun_facts")
  cardCategory          String   @default("SPORTS") @map("card_category") // SPORTS, TCG, ENTERTAINMENT, COMIC_RELATED, MOVIE_TV, MUSIC, HISTORY, POLITICAL, CELEBRITY, GAMING, OTHER
  collectibleType       String   @default("SPORTS_CARD") @map("collectible_type") // SPORTS_CARD, TCG_CARD, NON_SPORTS_CARD, COMIC_BOOK, MEMORABILIA, TICKET, FIGURE, COIN, VINYL, VIDEO_GAME, SEALED_PRODUCT, OTHER
  franchise             String?
  characterName         String?  @map("character_name")
  actorName             String?  @map("actor_name")
  artistName            String?  @map("artist_name")
  subjectName           String?  @map("subject_name")
  universe              String?
  genre                 String?
  whyItMatters          String?  @map("why_it_matters")
  publicDataStatus      String   @default("VERIFIED") @map("public_data_status") // VERIFIED, USER_IMPORTED, NEEDS_REVIEW, ADMIN_VERIFIED
  sourceType            String?  @map("source_type") // ADMIN_IMPORT, USER_INVENTORY_IMPORT, USER_CONTRIBUTION, MANUAL_ADMIN
  createdFromImportBatchId String? @map("created_from_import_batch_id")
  createdByUserId       String?  @map("created_by_user_id")
  collectibleId         String?  @unique @map("collectible_id")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  person          Person?          @relation(fields: [personId], references: [id])
  set             CardSet?         @relation(fields: [setId], references: [id])
  team            Team?            @relation(fields: [teamId], references: [id])
  grades          Grade[]
  collectionCards CollectionCard[]
  transactions    Transaction[]
  qrScans         QrScan[]
  media           CardMedia[]
  cardImages      CardImage[]
  inventoryItems  InventoryItem[]

  @@map("cards")
}

model Grade {
  id             String   @id @default(cuid())
  cardId         String   @map("card_id")
  gradingCompany String   @map("grading_company")
  grade          String
  certNumber     String?  @map("cert_number")
  gradedDate     String?  @map("graded_date")
  createdAt      DateTime @default(now()) @map("created_at")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("grades")
}

model Collection {
  id          String   @id @default(cuid())
  ownerName   String   @map("owner_name")
  title       String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  cards CollectionCard[]

  @@map("collections")
}

model CollectionCard {
  id           String @id @default(cuid())
  collectionId String @map("collection_id")
  cardId       String @map("card_id")
  quantity     Int    @default(1)

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  card       Card       @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([collectionId, cardId])
  @@map("collection_cards")
}

model Transaction {
  id              String   @id @default(cuid())
  cardId          String   @map("card_id")
  purchasePrice   Float?   @map("purchase_price")
  salePrice       Float?   @map("sale_price")
  transactionDate String?  @map("transaction_date")
  marketplace     String?
  buyer           String?
  seller          String?
  createdAt       DateTime @default(now()) @map("created_at")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model QrScan {
  id        String   @id @default(cuid())
  cardId    String   @map("card_id")
  scannedAt DateTime @default(now()) @map("scanned_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("qr_scans")
}

model CardMedia {
  id        String   @id @default(cuid())
  cardId    String   @map("card_id")
  type      String
  url       String
  caption   String?
  platform  String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("card_media")
}

model CardImage {
  id                String   @id @default(cuid())
  cardId            String   @map("card_id")
  imageType         String   @map("image_type") // FRONT, BACK
  sourceType        String   @map("source_type") // USER_UPLOAD, PUBLIC_REFERENCE, LICENSED, AI_GENERATED, ADMIN_UPLOAD
  displayUrl        String?  @map("display_url")
  thumbUrl          String?  @map("thumb_url")
  originalUrl       String?  @map("original_url")
  sourceUrl         String?  @map("source_url")
  sourceName        String?  @map("source_name")
  licenseType       String?  @map("license_type")
  attributionText   String?  @map("attribution_text")
  permissionStatus  String   @default("UNKNOWN") @map("permission_status") // UNKNOWN, ALLOWED, LICENSED, NEEDS_REVIEW, REJECTED
  copyrightNotes    String?  @map("copyright_notes")
  createdByUserId   String?  @map("created_by_user_id")
  reviewedByAdminId String?  @map("reviewed_by_admin_id")
  reviewedAt        DateTime? @map("reviewed_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("card_images")
}

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("admins")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String?  @unique
  passwordHash String   @map("password_hash")
  displayName  String?  @map("display_name")
  role         String   @default("USER") // USER, ADMIN
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  inventoryItems  InventoryItem[]
  inventoryGroups InventoryGroup[]

  @@map("users")
}

model InventoryItem {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  cardId          String    @map("card_id")
  comicIssueId    String?   @map("comic_issue_id")
  collectibleId   String?   @map("collectible_id")
  collectibleType String    @default("SPORTS_CARD") @map("collectible_type") // SPORTS_CARD, TCG_CARD, NON_SPORTS_CARD, COMIC_BOOK, MEMORABILIA, SEALED_PRODUCT, OTHER
  quantity        Int       @default(1)
  condition       String?   // RAW, PSA, BGS, SGC, CGC, CBCS, PGX
  gradeCompany    String?   @map("grade_company")
  gradeValue      String?   @map("grade_value")
  certNumber      String?   @map("cert_number")
  signed          Boolean   @default(false)
  witnessedSignature Boolean @default(false) @map("witnessed_signature")
  pressed         Boolean   @default(false)
  cleaned         Boolean   @default(false)
  acquisitionDate DateTime? @map("acquisition_date")
  purchasePrice   Float?    @map("purchase_price")
  estimatedValue  Float?    @map("estimated_value")
  askingPrice     Float?    @map("asking_price")
  status          String    @default("OWNED") // OWNED, FOR_SALE, SOLD, TRADE_ONLY, WATCHLIST
  storageLocation String?   @map("storage_location")
  notes           String?
  privateImageUrl String?   @map("private_image_url")
  frontScanUrl    String?   @map("front_scan_url")
  backScanUrl     String?   @map("back_scan_url")
  storagePath     String?   @map("storage_path")
  publicId        String?   @unique @map("public_id")
  passportEnabled Boolean   @default(false) @map("passport_enabled")
  passportVisibility String @default("PRIVATE") @map("passport_visibility") // PRIVATE, PUBLIC_BASIC, PUBLIC_FOR_SALE, TRANSFER_VERIFICATION
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  card         Card                   @relation(fields: [cardId], references: [id])
  transactions InventoryTransaction[]
  groupItems   InventoryGroupItem[]

  @@map("inventory_items")
}

model InventoryTransaction {
  id              String    @id @default(cuid())
  inventoryItemId String    @map("inventory_item_id")
  type            String    // PURCHASE, SALE, TRADE, GRADE_SUBMISSION, VALUE_UPDATE
  amount          Float?
  marketplace     String?
  counterparty    String?
  transactionDate DateTime? @map("transaction_date")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@map("inventory_transactions")
}

model Report {
  id           String   @id @default(cuid())
  type         String   // INCORRECT_INFO, COPYRIGHT, OFFENSIVE, FAKE_SCAM, DUPLICATE
  targetType   String   @map("target_type") // CARD, PLAYER, IMAGE, INVENTORY
  targetId     String   @map("target_id")
  reportedById String?  @map("reported_by_id")
  reason       String
  status       String   @default("OPEN") // OPEN, REVIEWING, RESOLVED, DISMISSED
  resolvedById String?  @map("resolved_by_id")
  resolvedAt   DateTime? @map("resolved_at")
  resolution   String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("reports")
}

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String   @map("actor_user_id")
  targetUserId String?  @map("target_user_id")
  entityType   String   @map("entity_type") // INVENTORY_ITEM, INVENTORY_GROUP, LISTING, TRANSFER, CARD, CARD_SET, USER
  entityId     String   @map("entity_id")
  action       String   // CREATED, UPDATED, DELETED, LISTED, SOLD, TRANSFER_INITIATED, TRANSFER_ACCEPTED, TRANSFER_DECLINED, MEDIA_UPLOADED, STATUS_CHANGED
  beforeJson   String?  @map("before_json")
  afterJson    String?  @map("after_json")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([actorUserId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model InventoryGroup {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  cardSetId       String?   @map("card_set_id")
  name            String
  description     String?
  groupType       String    @map("group_type") // COMPLETE_SET, PARTIAL_SET, LOT, BINDER, BOX, PACK, CASE, SEALED_PRODUCT, OPENED_PRODUCT
  status          String    @default("OWNED") // OWNED, FOR_SALE, SOLD, TRADE_ONLY, OPENED
  sealed          Boolean   @default(false)
  quantity        Int       @default(1)
  purchasePrice   Float?    @map("purchase_price")
  estimatedValue  Float?    @map("estimated_value")
  askingPrice     Float?    @map("asking_price")
  acquisitionDate DateTime? @map("acquisition_date")
  storageLocation String?   @map("storage_location")
  notes           String?
  frontImageUrl   String?   @map("front_image_url")
  backImageUrl    String?   @map("back_image_url")
  privateImageUrl String?   @map("private_image_url")
  storagePath     String?   @map("storage_path")
  publicId        String?   @unique @map("public_id")
  passportEnabled Boolean   @default(false) @map("passport_enabled")
  passportVisibility String @default("PRIVATE") @map("passport_visibility") // PRIVATE, PUBLIC_BASIC, PUBLIC_FOR_SALE, TRANSFER_VERIFICATION
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardSet CardSet? @relation(fields: [cardSetId], references: [id])
  items   InventoryGroupItem[]

  @@map("inventory_groups")
}

model InventoryGroupItem {
  id               String   @id @default(cuid())
  inventoryGroupId String   @map("inventory_group_id")
  inventoryItemId  String   @map("inventory_item_id")
  quantity         Int      @default(1)
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  group         InventoryGroup @relation(fields: [inventoryGroupId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem  @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([inventoryGroupId, inventoryItemId])
  @@map("inventory_group_items")
}

model Listing {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  inventoryItemId  String?   @map("inventory_item_id")
  inventoryGroupId String?   @map("inventory_group_id")
  listingType      String    @map("listing_type") // ITEM, GROUP
  status           String    @default("DRAFT") // DRAFT, ACTIVE, PAUSED, RESERVED, SOLD, CANCELLED
  price            Float?
  minimumOffer     Float?    @map("minimum_offer")
  allowOffers      Boolean   @default(false) @map("allow_offers")
  allowTrades      Boolean   @default(false) @map("allow_trades")
  buyNowEnabled    Boolean   @default(true) @map("buy_now_enabled")
  quantityAvailable Int      @default(1) @map("quantity_available")
  description      String?
  shippingNotes    String?   @map("shipping_notes")
  soldAt           DateTime? @map("sold_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@map("listings")
}

model OwnershipTransfer {
  id               String    @id @default(cuid())
  fromUserId       String    @map("from_user_id")
  toUserId         String    @map("to_user_id")
  inventoryItemId  String?   @map("inventory_item_id")
  inventoryGroupId String?   @map("inventory_group_id")
  listingId        String?   @map("listing_id")
  transferType     String    @map("transfer_type") // SALE, TRADE, GIFT, PRIVATE_TRANSFER
  status           String    @default("PENDING") // PENDING, ACCEPTED, DECLINED, CANCELLED
  transferPrice    Float?    @map("transfer_price")
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at")
  acceptedAt       DateTime? @map("accepted_at")
  declinedAt       DateTime? @map("declined_at")
  cancelledAt      DateTime? @map("cancelled_at")

  @@map("ownership_transfers")
}

model MarketValueSnapshot {
  id               String   @id @default(cuid())
  cardId           String?  @map("card_id")
  inventoryItemId  String?  @map("inventory_item_id")
  inventoryGroupId String?  @map("inventory_group_id")
  source           String   // MANUAL, EBAY, ALT, CARD_LADDER, PSA, COMC, USER_ESTIMATE
  value            Float
  currency         String   @default("USD")
  gradeCompany     String?  @map("grade_company")
  gradeValue       String?  @map("grade_value")
  capturedAt       DateTime @default(now()) @map("captured_at")
  metadata         String?  // JSON

  @@index([cardId, capturedAt])
  @@index([inventoryItemId, capturedAt])
  @@index([inventoryGroupId, capturedAt])
  @@map("market_value_snapshots")
}

model WishlistItem {
  id                  String   @id @default(cuid())
  userId              String   @map("user_id")
  cardId              String?  @map("card_id")
  cardSetId           String?  @map("card_set_id")
  collectibleCategory String?  @map("collectible_category")
  priority            String   @default("MEDIUM") // LOW, MEDIUM, HIGH, GRAIL
  targetPrice         Float?   @map("target_price")
  desiredGradeCompany String?  @map("desired_grade_company")
  desiredGradeValue   String?  @map("desired_grade_value")
  notes               String?
  status              String   @default("ACTIVE") // ACTIVE, ACQUIRED, ARCHIVED
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([userId, status])
  @@map("wishlist_items")
}

model Notification {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  type       String   // TRANSFER_RECEIVED, TRANSFER_ACCEPTED, TRANSFER_DECLINED, LISTING_SOLD, LISTING_CREATED, MARKET_VALUE_CHANGED, WISHLIST_MATCH, SET_COMPLETION, GROUP_OPENED, CARD_ADDED, MEDIA_UPLOADED, SYSTEM
  title      String
  message    String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  read       Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, read, createdAt])
  @@map("notifications")
}

model Offer {
  id            String   @id @default(cuid())
  listingId     String   @map("listing_id")
  buyerUserId   String   @map("buyer_user_id")
  sellerUserId  String   @map("seller_user_id")
  amount        Float?
  message       String?
  status        String   @default("PENDING") // PENDING, ACCEPTED, DECLINED, COUNTERED, CANCELLED
  counterAmount Float?   @map("counter_amount")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([buyerUserId])
  @@index([sellerUserId])
  @@index([listingId])
  @@map("offers")
}

model UserReputation {
  id                 String   @id @default(cuid())
  userId             String   @unique @map("user_id")
  totalSales         Int      @default(0) @map("total_sales")
  totalPurchases     Int      @default(0) @map("total_purchases")
  completedTransfers Int      @default(0) @map("completed_transfers")
  positiveFeedback   Int      @default(0) @map("positive_feedback")
  neutralFeedback    Int      @default(0) @map("neutral_feedback")
  negativeFeedback   Int      @default(0) @map("negative_feedback")
  reputationScore    Float    @default(0) @map("reputation_score")
  verifiedCollector  Boolean  @default(false) @map("verified_collector")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("user_reputations")
}

model Feedback {
  id         String   @id @default(cuid())
  fromUserId String   @map("from_user_id")
  toUserId   String   @map("to_user_id")
  transferId String?  @map("transfer_id")
  listingId  String?  @map("listing_id")
  rating     String   // POSITIVE, NEUTRAL, NEGATIVE
  comment    String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([toUserId])
  @@map("feedbacks")
}

model Dispute {
  id              String    @id @default(cuid())
  openedByUserId  String    @map("opened_by_user_id")
  againstUserId   String    @map("against_user_id")
  listingId       String?   @map("listing_id")
  offerId         String?   @map("offer_id")
  transferId      String?   @map("transfer_id")
  status          String    @default("OPEN") // OPEN, UNDER_REVIEW, WAITING_FOR_BUYER, WAITING_FOR_SELLER, RESOLVED, CLOSED, CANCELLED
  reason          String    // ITEM_NOT_RECEIVED, ITEM_NOT_AS_DESCRIBED, DAMAGED_IN_TRANSIT, COUNTERFEIT_CONCERN, PAYMENT_ISSUE, TRANSFER_ISSUE, OTHER
  description     String
  resolution      String?   // REFUND, PARTIAL_REFUND, RETURN, NO_ACTION, ACCOUNT_ACTION, OTHER
  adminNotes      String?   @map("admin_notes")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  resolvedAt      DateTime? @map("resolved_at")

  messages DisputeMessage[]

  @@index([openedByUserId])
  @@index([againstUserId])
  @@map("disputes")
}

model DisputeMessage {
  id            String   @id @default(cuid())
  disputeId     String   @map("dispute_id")
  userId        String   @map("user_id")
  message       String
  attachmentUrl String?  @map("attachment_url")
