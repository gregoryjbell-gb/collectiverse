  updatedAt   DateTime @updatedAt @map("updated_at")

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([userId])
  @@map("sale_expenses")
}

model ShippingAddress {
