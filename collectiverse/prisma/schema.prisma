model ImportJob {
  id                String    @id @default(cuid())
  connectorId       String    @map("connector_id")
  dataSourceId      String?   @map("data_source_id")
  status            String    @default("QUEUED") // QUEUED, RUNNING, PREVIEW_READY, IMPORTED, FAILED, CANCELLED
  inputFileUrl      String?   @map("input_file_url")
  inputUrl          String?   @map("input_url")
  totalRecords      Int       @default(0) @map("total_records")
  validRecords      Int       @default(0) @map("valid_records")
  duplicateRecords  Int       @default(0) @map("duplicate_records")
  conflictedRecords Int       @default(0) @map("conflicted_records")
  errorRecords      Int       @default(0) @map("error_records")
